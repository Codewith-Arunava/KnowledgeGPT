# ================================================================
# KnowledgeGPT - Environment Variables
# ================================================================

# --- App ---
APP_NAME=KnowledgeGPT
APP_ENV=development
DEBUG=true
SECRET_KEY=knowledgegpt-secret-key-change-in-production-32ch

# --- PostgreSQL (Migrated to SQLite) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledgegpt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DATABASE_URL=sqlite+aiosqlite:///./knowledgegpt.db

# --- JWT ---
JWT_SECRET_KEY=knowledgegpt-jwt-secret-key-production-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI ---
OPENAI_API_KEY=sk-abcdef1234567890abcdef1234567890abcdef12
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_DEFAULT_EMBEDDING=text-embedding-3-small

# --- Google Gemini (optional) ---
GOOGLE_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# --- ChromaDB ---
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./chromadb_data

# --- Pinecone (Optional) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=knowledgegpt

# --- Default Vector Store ---
# Options: chromadb | pinecone
DEFAULT_VECTOR_STORE=chromadb

# --- Default Retriever ---
# Options: langchain | llamaindex
DEFAULT_RETRIEVER=langchain

# --- LangSmith (Optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=knowledgegpt

# --- Tavily Web Search (Optional) ---
TAVILY_API_KEY=
SERPER_API_KEY=

# --- File Upload ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Embedding ---
DEFAULT_EMBEDDING_MODEL=openai-small

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7
